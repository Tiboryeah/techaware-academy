# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
USE_IN_MEMORY_DB=false

# Security
JWT_SECRET=your_jwt_secret_key
ADMIN_SEED_EMAIL=admin@kuxipilli.com
ADMIN_SEED_PASSWORD=your_strong_admin_password
# Comma-separated list of allowed frontend origins (e.g. Netlify URL + localhost)
ALLOWED_ORIGINS=https://kuxipilli.com,https://www.kuxipilli.com,http://localhost:5173

# Gemini AI (primary chatbot provider)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
USE_MOCK_AI=true

# Groq AI (free fallback when Gemini quota is exhausted — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Email (Optional/Notifications)
EMAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=your_email@gmail.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
USE_MOCK_EMAIL=true
